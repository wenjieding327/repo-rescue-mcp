REPO_RESCUE_HOST=0.0.0.0
REPO_RESCUE_PORT=8000
# Execution is refused unless the normalized owner/repository is listed here.
# Inspection remains available for any public GitHub repository.
REPO_RESCUE_ALLOWED_REPOS=pallets/click
REPO_RESCUE_PYTHON_IMAGE=repo-rescue-python:3.11
# Use direct only inside a trusted managed host; it still enforces the repository and command allow-lists.
REPO_RESCUE_EXECUTION_BACKEND=docker
REPO_RESCUE_TRANSPORT=streamable-http
REPO_RESCUE_MAX_REPO_MB=50
REPO_RESCUE_INSTALL_TIMEOUT_SECONDS=180
REPO_RESCUE_RUN_TIMEOUT_SECONDS=60
